{
  "name": "graph-memory-pro",
  "version": "2.1.0",
  "description": "Neo4j Knowledge Graph Memory Engine for OpenClaw — GDS PageRank, community detection, vector index",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "node build.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:old": "esbuild index.ts --bundle --outfile=dist/index.js --format=esm --platform=node --target=es2022 --external:openclaw --external:neo4j-driver --tsconfig=tsconfig.json"
  },
  "dependencies": {
    "neo4j-driver": "^5.27.0",
    "typebox": "^1.1.39"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "tsx": "^4.19.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    }
  }
}

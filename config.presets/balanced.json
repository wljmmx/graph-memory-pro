{
  "$comment": "平衡配置预设（推荐）：在 minimal 基础上开启核心召回增强功能（judge Tier 1 启发式 + queryCache + temporal + staleness + graphHealth + state + causalEdges + feedback），关闭需要 warmup 或额外配置的高级功能（associationMatrix / autoTuner / mcp）和高级图算法（marginalUtility / evolvableEmbedding / importance / hierarchicalCommunity / conflictResolution / edgeWeights / reverseMemory）。适用场景：生产环境推荐起点。配置值参考 config.example.json 默认值。Ollama LLM baseURL 含 /v1，Embedding baseURL 不含 /v1。",
  "neo4j": {
    "uri": "bolt://localhost:7687",
    "user": "neo4j",
    "password": "your-password-here"
  },
  "llm": {
    "$comment": "Ollama LLM 端点：baseURL 必须含 /v1；Ollama 用法下 apiKey 替换为空字符串；OpenAI 用户改 baseURL 为 https://api.openai.com/v1 并填 sk-xxx",
    "apiKey": "your-llm-api-key-here",
    "baseURL": "http://localhost:11434/v1",
    "model": "qwen2.5:7b",
    "keepAlive": "5m"
  },
  "embedding": {
    "$comment": "Ollama Embedding 端点：baseURL 不含 /v1；Ollama 用法下 apiKey 替换为空字符串；模型须为 embedding 模型",
    "apiKey": "your-embedding-api-key-here",
    "baseURL": "http://localhost:11434",
    "model": "nomic-embed-text",
    "dimensions": 768,
    "keepAlive": -1
  },
  "recallMaxNodes": 6,
  "recallMaxDepth": 2,
  "freshTailCount": 10,
  "dedupThreshold": 0.9,
  "pagerankDamping": 0.85,
  "pagerankIterations": 20,
  "compactTurnCount": 6,
  "timing": { "enabled": false, "reportEveryN": 50 },
  "background": {
    "extractorIntervalMs": 60000,
    "maintenanceIntervalMs": 21600000
  },
  "temporal": { "enabled": true, "defaultSource": "experience" },
  "state": { "enabled": true, "filterSupersededInRecall": false },
  "staleness": { "enabled": true, "threshold": 0.7, "mode": "heuristic" },
  "causalEdges": { "enabled": true, "extract": true },
  "graphHealth": { "enabled": true, "alertOnAnomaly": true },
  "queryCache": {
    "enabled": true,
    "maxSize": 100,
    "ttlMs": 1800000,
    "similarityThreshold": 0.95
  },
  "judge": {
    "enabled": true,
    "asyncMode": true,
    "judgeWarmupFeedbacks": 50,
    "heuristicMatch": "both",
    "tier": 1,
    "llmJudgeMaxNodes": 10,
    "llmJudgeTimeoutMs": 8000,
    "customStrategy": ""
  },
  "feedback": { "enabled": true, "retentionDays": 90 },
  "warmup": { "warmupFeedbacks": 100, "judgeWarmupFeedbacks": 50 },
  "associationMatrix": {
    "enabled": false,
    "learningRate": 0.01,
    "momentum": 0.9,
    "adamBeta1": 0.9,
    "adamBeta2": 0.999,
    "warmupFeedbacks": 100
  },
  "marginalUtility": { "enabled": false, "neighborhoodSize": 5, "minImprovement": 0.0 },
  "evolvableEmbedding": {
    "enabled": false,
    "reembedOnContentChange": true,
    "archiveKeepCount": 3
  },
  "importance": {
    "enabled": false,
    "weights": { "recency": 0.3, "frequency": 0.3, "centrality": 0.2, "source": 0.2 },
    "recencyDecayDays": 30,
    "frequencySaturation": 10
  },
  "hierarchicalCommunity": { "enabled": false, "depth": 3 },
  "conflictResolution": {
    "enabled": false,
    "temporalPriority": true,
    "sourcePriority": true,
    "confidencePriority": true
  },
  "edgeWeights": {
    "enabled": false,
    "strengthenFactor": 1.1,
    "decayFactor": 0.95,
    "minWeight": 0.1,
    "maxWeight": 5.0
  },
  "reverseMemory": {
    "enabled": false,
    "recallThreshold": 10,
    "stalenessPenalty": 0.1,
    "importanceFloor": 0.2
  },
  "benchmark": {
    "enabled": false,
    "dataDir": "",
    "maxCases": 50,
    "buildGraph": true,
    "caseTimeoutMs": 30000
  },
  "autoTuner": {
    "enabled": false,
    "regressionThreshold": 0.02,
    "stagnationThreshold": 5,
    "maxRounds": 10,
    "benchmarkMaxCases": 50,
    "llmDiagnosis": true,
    "warmupFeedbacks": 100
  },
  "mcp": {
    "enabled": false,
    "port": 7800,
    "host": "127.0.0.1",
    "path": "/mcp",
    "authToken": "",
    "enabledTools": []
  }
}
